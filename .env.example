# Copy to .env for local development. None of these are required — the
# defaults in chorus/utils/env_cfg.py boot the app against a local
# vllm-router/Neo4j. Override here when you need to point at a remote
# stack or change provider behaviour.

INFERENCE_PROVIDER=vllm
OPENAI_API_BASE=http://vllm-router:4000/v1
OPENAI_API_KEY=EMPTY

TEXT_MODEL=
EMBED_MODEL=
RERANK_MODEL=
EMBED_DIM=1024

# --- NER / GLiNER ---
# NER is decoupled from INFERENCE_PROVIDER: it speaks the GLiNER-native
# /gliner HTTP shape, not the OpenAI protocol. This lets you run e.g.
# Ollama for chat/embed/rerank and vllm-service ner-only for NER on the
# same host (typical dev Mac / CPU-only Linux setup).
#
# Two deployment shapes are supported by the same code:
#   - Full vllm-service stack: NER_API_BASE=http://vllm-router:4000 with
#     NER_API_KEY=$OPENAI_API_KEY (LiteLLM router enforces Bearer auth).
#   - ner-only stack: NER_API_BASE=http://gliner-ner:8000 (no auth,
#     trust inference-net) — leave NER_API_KEY unset.
#
# NER_API_KEY is NOT auto-derived from OPENAI_API_KEY: on multi-provider
# hosts the two are genuinely different and an implicit alias would
# hide that. Set it explicitly when you need it.
#
# NER_ENABLED gates the orchestrator's extraction step entirely — set
# it to false in dev environments that lack a reachable GLiNER service
# to avoid a connect-failure warning per ingested post.
#
# NER_MODEL_VERSION is stamped on every :MENTIONS edge for provenance.
# The /gliner endpoint itself takes no model parameter, so chorus does
# not introspect the service for this — set it to match whatever GLiNER
# build the vllm-service side actually has loaded.
# NER_ENABLED=true
# NER_API_BASE=http://vllm-router:4000
# NER_API_KEY=
# NER_THRESHOLD=0.3
# NER_TIMEOUT=30
# NER_MODEL_VERSION=gliner-community/gliner_large-v2.5

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j
NEO4J_DATABASE=neo4j

CHORUS_AUTH_HEADER=X-Auth-User
CHORUS_DEFAULT_IDENTITY=dev   # leave unset in production

LOG_LEVEL=INFO
LOG_FORMAT=text                # set to "json" in production
