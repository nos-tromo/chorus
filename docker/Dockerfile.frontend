### chorus UI image — same multi-stage pattern as the API image.

ARG UV_IMAGE=ghcr.io/astral-sh/uv:0.11.9-python3.12-trixie-slim@sha256:26c7a2f9dcbaf11fb7822963640ab60a4e0f6b23e9ba5a31a88686146003f83e
FROM ${UV_IMAGE} AS builder

ENV UV_CACHE_DIR=/root/.cache/uv \
    UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/app/.venv

WORKDIR /app

# Install only the frontend dependency group (Streamlit + httpx +
# python-dotenv). The UI talks to the API over HTTP and imports only
# `chorus.ui` and `chorus.utils` (the localization catalog + its env loader),
# so it needs neither the backend libraries (neo4j, openai, fastapi, …) nor the
# project wheel itself — hence --only-group and --no-install-project.
RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,source=uv.lock,target=uv.lock \
    --mount=type=bind,source=pyproject.toml,target=pyproject.toml \
    uv sync --locked --only-group frontend --no-install-project

FROM ${UV_IMAGE}
ENV PYTHONUNBUFFERED=1 \
    VIRTUAL_ENV=/app/.venv \
    PATH="/app/.venv/bin:${PATH}" \
    UV_PROJECT_ENVIRONMENT=/app/.venv \
    PYTHONPATH=/app \
    STREAMLIT_SERVER_HEADLESS=true \
    STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

WORKDIR /app
# Copy just the prebuilt venv and the source the UI imports. chorus/__init__.py
# (a bare version string, no backend imports) makes `chorus` a package;
# PYTHONPATH=/app lets the un-installed `from chorus.ui...` / `from chorus.utils...`
# imports resolve over the copied source. chorus/utils carries the localization
# catalog (`ui_strings`) and its env loader (`env_cfg`), which every page imports;
# omitting it makes the image boot but crash every page with ModuleNotFoundError
# (guarded by tests/ui/test_frontend_image_surface.py).
COPY --from=builder /app/.venv /app/.venv
COPY chorus/__init__.py /app/chorus/__init__.py
COPY chorus/ui /app/chorus/ui
COPY chorus/utils /app/chorus/utils

EXPOSE 8501

CMD ["streamlit", "run", "chorus/ui/streamlit_app.py", \
     "--server.port=8501", "--server.address=0.0.0.0"]
